# Copy this file to .env for local development.
# Never commit real secrets. Keep production values in a secret manager.

APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CA_BUNDLE=
AWS_VERIFY_SSL=true

S3_BUCKET_NAME=your-s3-bucket-name
S3_STORAGE_BACKEND=mock
S3_UPLOAD_PREFIX=storage/upload_files
S3_TEMPLATE_PREFIX=storage/template_files
S3_GENERATED_PREFIX=storage/generated_files

BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5
BEDROCK_INFERENCE_PROFILE_ID=
BEDROCK_CONNECT_TIMEOUT_SECONDS=10
BEDROCK_READ_TIMEOUT_SECONDS=900
BEDROCK_MAX_ATTEMPTS=3

DATABASE_URL=sqlite+aiosqlite:///./finpm.db
DATABASE_SSL_VERIFY=true
SQLALCHEMY_ECHO=false
SQLALCHEMY_HIDE_PARAMETERS=true

GENERATION_RETRIEVAL_TOP_K=80
GENERATION_MAX_SOURCE_CHUNKS=80
GENERATION_REQUIREMENT_BATCH_SIZE=8
GENERATION_REQUIREMENT_RETRIEVAL_TOP_K=40
GENERATION_REQUIREMENT_TABLE_BATCH_SIZE=4
GENERATION_REQUIREMENT_SOURCE_TEXT_LIMIT=1800

EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DIMENSIONS=1024
EMBEDDING_NORMALIZE=true

UPLOAD_MAX_BYTES=26214400
UPLOAD_READ_CHUNK_BYTES=1048576
UPLOAD_MAX_PDF_PAGES=200
UPLOAD_MAX_SPREADSHEET_SHEETS=20
UPLOAD_MAX_SPREADSHEET_ROWS=10000
