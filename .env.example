# Copy this file to .env in the backend directory.
# For real AWS/Aurora integration, fill AWS keys and DATABASE_URL below.

APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AWS credentials can be left empty only when using an IAM role/profile.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional corporate CA bundle path. Prefer this over disabling SSL verification.
AWS_CA_BUNDLE=
AWS_VERIFY_SSL=true

# S3 bucket and logical prefixes used by upload/template/generated-file flows.
S3_BUCKET_NAME=kbds-s3-finpm
# Use "s3" for real AWS S3 uploads. Use "mock" only for offline local demos.
S3_STORAGE_BACKEND=s3
S3_UPLOAD_PREFIX=storage/upload_files
S3_TEMPLATE_PREFIX=storage/template_files
S3_GENERATED_PREFIX=storage/generated_files

# Bedrock model used by app.core.llm.llm_service.
# BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Aurora PostgreSQL example for AWS pgvector.
DATABASE_URL=postgresql+asyncpg://postgres:finpm123!!@kbds-rds-finpm-db.cluster-c7koskw0kdf9.ap-northeast-2.rds.amazonaws.com:5432/finpm

# Vector store selection for runtime:
# - pgvector : EC2/Aurora environment
VECTOR_STORE_TYPE=pgvector



EMBEDDING_MODEL=BAAI/bge-m3

CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=150
WBS_BATCH_SIZE=10
SCREEN_BATCH_SIZE=10
BEDROCK_READ_TIMEOUT=300

RECREATE_COLLECTION=false
